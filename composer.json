{
  "name": "your-vendor/{{PLUGIN_SLUG}}",
  "description": "{{PLUGIN_NAME}} — a WordPress plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "wp-phpunit/wp-phpunit": "^6.4",
    "brain/monkey": "^2.6",
    "10up/wp_mock": "^0.5",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "*"
  },
  "autoload": {
    "psr-4": {
      "{{PLUGIN_CLASS}}\\": "includes/",
      "{{PLUGIN_CLASS}}\\Admin\\": "admin/",
      "{{PLUGIN_CLASS}}\\Frontend\\": "public/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "{{PLUGIN_CLASS}}\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test":       "phpunit --colors=always",
    "test:watch": "phpunit-watcher watch",
    "lint":       "phpcs --standard=WordPress .",
    "lint:fix":   "phpcbf --standard=WordPress .",
    "coverage":   "phpunit --coverage-html coverage/"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
